{
  "name": "steamdb-mini-frontend",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/generate-runtime-config.mjs",
    "start": "ng serve --port 4200",
    "prebuild": "node scripts/generate-runtime-config.mjs",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "vercel:build": "node scripts/vercel-build.mjs",
    "vercel:prepare-output": "node scripts/prepare-vercel-output.mjs",
    "redeploy:preview": "node scripts/fast-redeploy.mjs",
    "redeploy:preview:watch": "node scripts/fast-redeploy.mjs --watch",
    "redeploy:prod": "node scripts/fast-redeploy.mjs --prod",
    "redeploy:prod:watch": "node scripts/fast-redeploy.mjs --watch --prod"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.9",
    "@angular/common": "^21.2.9",
    "@angular/compiler": "^21.2.9",
    "@angular/core": "^21.2.9",
    "@angular/forms": "^21.2.9",
    "@angular/platform-browser": "^21.2.9",
    "@angular/platform-browser-dynamic": "^21.2.9",
    "@angular/router": "^21.2.9",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.16.0"  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.9",
    "typescript": "~5.9.3"

  }
}
